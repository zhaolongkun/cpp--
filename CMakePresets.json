        "CMAKE_BUILD_TYPE": "Release",
        "USE_SYSTEM_OPENCV": "ON",
        "USE_ONNXRUNTIME": "ON",
        "USE_SYSTEM_YAML_CPP": "OFF",
        "USE_SYSTEM_EIGEN3": "OFF",
        "OpenCV_DIR": "C:/Users/Administrator/miniconda3/envs/py310/Library/cmake/x64/vc17/lib",
        "ONNXRUNTIME_ROOT": "${sourceDir}/third_party/onnxruntime-win-x64-1.23.2"
      }
