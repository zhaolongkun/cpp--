  ],
  "buildPresets": [
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug",
      "inheritConfigureEnvironment": true
    },
    {
      "name": "msvc-opencv-release",
